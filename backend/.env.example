# Public-release env contract.
# Only variables referenced by the helper modules in backend/app/ are listed.
# The full backend uses additional env vars (Discord bot, AI pipeline,
# research, slab CDN, etc.) that are intentionally not documented here.

# ── Helius RPC (helius.py) ──────────────────────────────────────────
# Single key, or comma-separated fallback chain via HELIUS_API_KEYS.
HELIUS_API_KEY=
HELIUS_API_KEYS=

# ── Solana Actions / Blinks (marketplace_actions.py) ────────────────
# devnet | mainnet-beta. Selects the USDC mint default below.
SOLANA_ACTIONS_CLUSTER=devnet
# Backend that serves the Action handlers (Cloudflare Worker reverse-
# proxies /blinkitem/* on the public origin → this URL's /api/actions/*).
SOLANA_ACTIONS_BASE_URL=
# Branded public Blink origin — what users see in their wallet.
BLINK_PUBLIC_BASE=https://proofbyframe.com
# USDC SPL mints. Defaults are Circle's canonical mints; override only
# if running against a custom faucet mint.
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
